<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <Identity
    Name="StudioCodeAI.LyaCode"
    Publisher="CN=01417B77-C5A9-404C-9F0B-FA0F17FBC808"
    Version="1.2.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>LyaCode</DisplayName>
    <PublisherDisplayName>Studio CodeAI</PublisherDisplayName>
    <Description>Terminal agentico de IA da Studio CodeAI — compativel com Claude, Gemini, GPT, Ollama e mais</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="pt-BR" />
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application
      Id="LyaCode"
      Executable="lyacode-setup.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Lya Code"
        Description="Terminal agentico de IA da Studio CodeAI"
        BackgroundColor="#0D1117"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          ShortName="Lya Code" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <uap5:Extension
          Category="windows.appExecutionAlias"
          Executable="lyacode-setup.exe"
          EntryPoint="Windows.FullTrustApplication">
          <uap5:AppExecutionAlias>
            <uap5:ExecutionAlias Alias="lyacode.exe" />
            <uap5:ExecutionAlias Alias="lya.exe" />
            <uap5:ExecutionAlias Alias="lscode.exe" />
          </uap5:AppExecutionAlias>
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
