{
  "name": "lyacloud-vscode",
  "displayName": "Lya Cloud",
  "description": "Practical VS Code companion for Lya Cloud with project-aware launch, Control Center, optional Microsoft Foundry / Azure OpenAI terminal env, and chat.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lyacloud.start",
    "onCommand:lyacloud.startInWorkspaceRoot",
    "onCommand:lyacloud.openDocs",
    "onCommand:lyacloud.openSetupDocs",
    "onCommand:lyacloud.openWorkspaceProfile",
    "onCommand:lyacloud.openControlCenter",
    "onCommand:lyacloud.newChat",
    "onCommand:lyacloud.openChat",
    "onCommand:lyacloud.resumeSession",
    "onCommand:lyacloud.abortChat",
    "onCommand:lyacloud.setAzureApiKey",
    "onCommand:lyacloud.clearAzureApiKey",
    "onCommand:lyacloud.configureAzureChat",
    "onCommand:lyacloud.openAzureSettings",
    "onView:lyacloud.controlCenter",
    "onView:lyacloud.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lyacloud.start",
        "title": "Lya Cloud: Launch in Terminal",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.startInWorkspaceRoot",
        "title": "Lya Cloud: Launch in Workspace Root",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openDocs",
        "title": "Lya Cloud: Open Repository",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openSetupDocs",
        "title": "Lya Cloud: Open Setup Guide",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openWorkspaceProfile",
        "title": "Lya Cloud: Open Workspace Profile",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openControlCenter",
        "title": "Lya Cloud: Open Control Center",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.newChat",
        "title": "Lya Cloud: New Chat",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openChat",
        "title": "Lya Cloud: Open Chat Panel",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.resumeSession",
        "title": "Lya Cloud: Resume Session",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.abortChat",
        "title": "Lya Cloud: Abort Generation",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.setAzureApiKey",
        "title": "Lya Cloud: Set Azure / Foundry API Key (Secret Storage)",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.clearAzureApiKey",
        "title": "Lya Cloud: Clear Azure / Foundry API Key",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.configureAzureChat",
        "title": "Lya Cloud: Configure Azure / Foundry Chat (wizard)",
        "category": "Lya Cloud"
      },
      {
        "command": "lyacloud.openAzureSettings",
        "title": "Lya Cloud: Open Azure / Foundry Settings",
        "category": "Lya Cloud"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lyacloud",
          "title": "Lya Cloud",
          "icon": "media/lyacloud.svg"
        }
      ]
    },
    "views": {
      "lyacloud": [
        {
          "id": "lyacloud.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "lyacloud.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lyacloud.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Lya Cloud",
      "properties": {
        "lyacloud.launchCommand": {
          "type": "string",
          "default": "lyacloud",
          "description": "Command run in the integrated terminal when launching Lya Cloud."
        },
        "lyacloud.terminalName": {
          "type": "string",
          "default": "Lya Cloud",
          "description": "Integrated terminal tab name for Lya Cloud sessions."
        },
        "lyacloud.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched Lya Cloud terminals when Azure injection is off or incomplete."
        },
        "lyacloud.azure.enabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, launch injects Microsoft Foundry / Azure OpenAI-compatible chat env (OPENAI_* + AZURE_OPENAI_API_VERSION) into the Lya Cloud terminal."
        },
        "lyacloud.azure.endpoint": {
          "type": "string",
          "default": "",
          "markdownDescription": "Azure resource base URL for OpenAI-compatible chat (example: `https://YOUR_RESOURCE.openai.azure.com`). Do not put `api-version` here; use **Lya Cloud: Azure API Version**."
        },
        "lyacloud.azure.apiVersion": {
          "type": "string",
          "default": "2024-12-01-preview",
          "description": "Azure API version for chat completions (AZURE_OPENAI_API_VERSION)."
        },
        "lyacloud.azure.deployment": {
          "type": "string",
          "default": "",
          "markdownDescription": "Azure deployment name (maps to `OPENAI_MODEL` for the OpenAI shim)."
        },
        "lyacloud.azure.forceAzureUrlStyle": {
          "type": "boolean",
          "default": true,
          "description": "Sets OPENAI_AZURE_STYLE=1 so deployment URLs and api-key header work on Foundry and non-standard Azure hosts."
        },
        "lyacloud.azure.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional API key in settings (not recommended). Prefer **Lya Cloud: Set Azure / Foundry API Key**. Secret wins if both are set."
        },
        "lyacloud.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode — no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "Lya Cloud Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/LyaCloud-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "bun test src",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "lyacloud",
    "terminal",
    "theme",
    "cli",
    "llm",
    "azure",
    "foundry"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/StudioCodeAI/lyacloud"
  },
  "license": "MIT"
}
